{
  "name": "@bromso/figma-mcp",
  "version": "1.1.0",
  "description": "Bridge between AI MCP clients and Figma. Stdio shim + daemon + bundled bridge plugin.",
  "homepage": "https://bromso.github.io/bro",
  "repository": {
    "type": "git",
    "url": "https://github.com/bromso/bro.git",
    "directory": "apps/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/bromso/bro/issues"
  },
  "license": "MIT",
  "author": "bromso",
  "keywords": [
    "figma",
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "cursor",
    "windsurf"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "type": "module",
  "main": "./dist/main.js",
  "bin": {
    "figma-mcp": "./dist/main.js"
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "types": "tsc --noEmit",
    "lint": "biome check .",
    "start": "bun src/main.ts",
    "build": "bun build src/main.ts --target=node --outdir=dist --external:* && bun run build:plugin",
    "build:plugin": "cd ../bridge-plugin && bun run build && cp -r dist/. ../mcp-server/dist/plugin/",
    "prepublishOnly": "cp ../../README.md ./README.md && cp ../../LICENSE ./LICENSE"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@repo/figma-adapter": "workspace:*",
    "@repo/figma-api-client": "workspace:*",
    "@repo/protocol": "workspace:*",
    "@repo/tools-console": "workspace:*",
    "@repo/tools-design": "workspace:*",
    "@repo/tools-extract": "workspace:*",
    "@repo/tools-figjam": "workspace:*",
    "@repo/tools-rest": "workspace:*",
    "@repo/tools-slides": "workspace:*",
    "@repo/tools-variables": "workspace:*",
    "@repo/transport": "workspace:*",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@repo/bridge-plugin": "workspace:*",
    "@types/node": "^25.0.0",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "4.1.4",
    "typescript": "^6.0.0",
    "vitest": "4.1.4",
    "ws": "^8.18.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
