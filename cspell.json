{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "useGitignore": true,
  "noConfigSearch": true,
  "files": [
    "**/*.{ts,tsx,js,jsx,mjs,cjs}",
    "**/*.{md,mdx}",
    "**/*.{json,jsonc}",
    "**/*.{scss,css}",
    "**/*.{html,svg}"
  ],
  "ignorePaths": [
    "node_modules",
    ".next",
    ".turbo",
    ".vite",
    ".cache",
    ".changeset",
    ".husky",
    ".vscode",
    "dist",
    "build",
    "coverage",
    "storybook-static",
    "bun.lock",
    "bun.lockb",
    "package-lock.json",
    "*.tsbuildinfo",
    "*.min.js",
    "*.min.css"
  ],
  "words": [
    "addgroup",
    "adduser",
    "bradlc",
    "bromso",
    "bunx",
    "catppuccin",
    "cmdk",
    "dockercompose",
    "esbenp",
    "eslintcache",
    "figjam",
    "formulahendry",
    "fumadocs",
    "graphqlrc",
    "iconify",
    "kohler",
    "libc",
    "libsql",
    "lighthouseci",
    "lockb",
    "nextjs",
    "Redbull",
    "serwist",
    "shadcn",
    "stylelintcache",
    "supabase",
    "tabler",
    "tsbuildinfo",
    "turbopack",
    "turborepo",
    "Turborepo",
    "vaul",
    "Vercel",
    "vincaslt",
    "vivaxy",
    "vsicons",
    "webben"
  ]
}
